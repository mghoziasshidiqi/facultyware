<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      document.addEventListener("basecoat:theme", (e) => {
        const m = e.detail?.mode;
        document.documentElement.classList.toggle("dark", m === "dark" ? true : m === "light" ? false : !document.documentElement.classList.contains("dark"));
        try { localStorage.setItem("themeMode", document.documentElement.classList.contains("dark") ? "dark" : "light"); } catch (_) {}
      });
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard - Facultyware</title>
  <link class="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="stylesheet" href="/assets/styles.css" />
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body>
  <%- include('./partials/sidebar') %>

  <main class="main">
    <div class="p-6 space-y-6">

      <div>
        <h1 class="text-2xl font-bold">Selamat datang, <%= user %> 👋</h1>
        <p class="text-muted-foreground text-sm mt-1">Sistem Pengelolaan Kerjasama - Facultyware</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

        <!-- Kartu 1: Daftar Kerjasama (Sekarang di Atas & Full Clickable) -->
        <a href="/kerjasama/master" class="card p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-briefcase"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </div>
            <div>
              <h2 class="font-semibold group-hover:text-primary transition-colors text-lg">Daftar Kerjasama</h2>
              <p class="text-sm text-muted-foreground mt-1">Kelola data kerjasama (CRUD)</p>
            </div>
          </div>
        </a>

        <!-- Kartu 2: Kerjasama Expired (Sekarang di Bawah) -->
        <a href="/kerjasama/expired" class="card p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h2 class="font-semibold group-hover:text-primary transition-colors text-lg">Kerjasama Expired</h2>
              <p class="text-sm text-muted-foreground mt-1">Pantau kerjasama yang sudah atau akan berakhir, dan kelola perpanjangannya</p>
            </div>
          </div>
        </a>

        <!-- Kartu 3: Implementation Arrangement -->
        <a href="/kerjasama/ia" class="card p-6 hover:shadow-md transition-shadow group">
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
              </svg>
            </div>
            <div>
              <h2 class="font-semibold group-hover:text-primary transition-colors text-lg">Implementation Arrangement</h2>
              <p class="text-sm text-muted-foreground mt-1">Kelola kegiatan IA, upload lampiran, dan ekspor data</p>
            </div>
          </div>
        </a>

      </div>

    </div>
  </main>

</body>
</html>