<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> - Facultyware</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="stylesheet" href="/assets/styles.css" />
</head>
<body>
  <%- include('../../partials/sidebar') %>

  <main class="main">
    <div class="p-6 max-w-2xl mx-auto space-y-6">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        <a href="/kerjasama/expired" class="hover:text-foreground">Kerjasama Expired</a>
        <span>/</span>
        <span class="text-foreground">Import</span>
      </nav>

      <h1 class="text-2xl font-bold">Import Perpanjangan Kerjasama</h1>

      <!-- Hasil import -->
      <% if (typeof successCount !== 'undefined') { %>
        <div class="rounded-md bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 p-4 text-green-800 dark:text-green-200 text-sm">
          ✓ Berhasil mengimpor <strong><%= successCount %></strong> data perpanjangan.
        </div>
      <% } %>

      <!-- Error messages -->
      <% if (errors && errors.length > 0) { %>
        <div class="rounded-md bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-4">
          <p class="font-medium text-red-800 dark:text-red-200 text-sm mb-2">
            Terdapat <%= errors.length %> kesalahan:
          </p>
          <ul class="list-disc list-inside text-red-700 dark:text-red-300 text-sm space-y-1 max-h-48 overflow-y-auto">
            <% errors.forEach(e => { %><li><%= e %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <!-- Form upload -->
      <div class="card p-6 space-y-4">
        <form method="POST" action="/kerjasama/expired/import" enctype="multipart/form-data" class="space-y-4" id="importForm">
          <div>
            <label for="file" class="label block mb-1">
              File CSV / Excel <span class="text-red-500">*</span>
            </label>
            <input
              type="file"
              id="file"
              name="file"
              accept=".csv,.xlsx,.xls"
              class="input w-full"
              required
            />
            <p class="text-xs text-muted-foreground mt-1">Maks. 5 MB. Format: .csv, .xlsx, .xls</p>
          </div>

          <div class="flex gap-3">
            <button type="submit" class="btn">Upload & Import</button>
            <a href="/kerjasama/expired" class="btn-outline">Kembali</a>
          </div>
        </form>
      </div>

      <!-- Panduan format file -->
      <div class="card p-6">
        <h2 class="font-semibold mb-3">Format File yang Diperlukan</h2>
        <p class="text-sm text-muted-foreground mb-3">
          File harus memiliki kolom berikut (nama kolom bisa menggunakan nama teknis atau nama tampilan):
        </p>
        <div class="overflow-x-auto">
          <table class="table w-full text-sm">
            <thead>
              <tr>
                <th>Nama Kolom Teknis</th>
                <th>Nama Kolom Tampilan</th>
                <th>Keterangan</th>
                <th>Wajib</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><code>partnership_id</code></td>
                <td>ID Kerjasama</td>
                <td>ID kerjasama di database</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>new_document_number</code></td>
                <td>Nomor Surat Baru</td>
                <td>Nomor surat perpanjangan</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>new_start_date</code></td>
                <td>Tanggal Mulai Baru</td>
                <td>Format: YYYY-MM-DD</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>new_end_date</code></td>
                <td>Tanggal Akhir Baru</td>
                <td>Format: YYYY-MM-DD</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>notes</code></td>
                <td>Catatan</td>
                <td>Catatan tambahan</td>
                <td><span class="badge">Tidak</span></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="mt-4 p-3 bg-muted rounded-md">
          <p class="text-xs font-mono text-muted-foreground">
            Contoh baris CSV:<br/>
            partnership_id,new_document_number,new_start_date,new_end_date,notes<br/>
            1,001/PKS/2026,2026-01-01,2028-12-31,Perpanjangan otomatis
          </p>
        </div>
      </div>

    </div>
  </main>

  <script>
    document.getElementById('importForm').addEventListener('submit', function(e) {
      const file = document.getElementById('file').files[0];
      if (!file) {
        e.preventDefault();
        alert('Pilih file terlebih dahulu');
        return;
      }
      const ext = file.name.split('.').pop().toLowerCase();
      if (!['csv', 'xlsx', 'xls'].includes(ext)) {
        e.preventDefault();
        alert('Format file tidak didukung. Gunakan .csv, .xlsx, atau .xls');
      }
    });
  </script>
</body>
</html>
