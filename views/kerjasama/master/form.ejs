<!doctype html>
<html lang="id">
<head>
  <script>
    (() => { try { const stored = localStorage.getItem("themeMode"); if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) { document.documentElement.classList.add("dark"); } } catch (_) {} })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> - Facultyware</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="stylesheet" href="/assets/styles.css" />
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body>
  <%- include('../../partials/sidebar') %>

  <main class="main">
    <div class="p-6 max-w-2xl mx-auto space-y-6">

      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        <a href="/kerjasama/master" class="hover:text-foreground">Daftar Kerjasama</a>
        <span>/</span>
        <span class="text-foreground"><%= partnership ? 'Edit' : 'Tambah' %> Data</span>
      </nav>

      <h1 class="text-2xl font-bold"><%= title %></h1>

      <div class="card p-6">
        <form method="POST" action="<%= partnership ? '/kerjasama/master/update/' + partnership.id : '/kerjasama/master/create' %>" class="space-y-4">
          
          <div>
            <label class="label block mb-1">Judul Kerjasama <span class="text-red-500">*</span></label>
            <input type="text" name="title" class="input w-full" value="<%= partnership ? partnership.title : '' %>" required />
          </div>

          <div>
            <label class="label block mb-1">Mitra Institusi <span class="text-red-500">*</span></label>
            <select name="partner_id" class="input w-full" required>
              <option value="">-- Pilih Mitra --</option>
              <% partners.forEach(p => { %>
                <option value="<%= p.id %>" <%= partnership && partnership.partner_id === p.id ? 'selected' : '' %>><%= p.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="label block mb-1">Nomor Dokumen <span class="text-red-500">*</span></label>
              <input type="text" name="document_number" class="input w-full" value="<%= partnership ? partnership.document_number : '' %>" required />
            </div>
            <div>
              <label class="label block mb-1">Jenis Dokumen</label>
              <select name="document_type" class="input w-full">
                <option value="mou" <%= partnership && (partnership.document_type === 'mou' || partnership.document_type === 'MoU') ? 'selected' : '' %>>MoU</option>
                <option value="moa" <%= partnership && (partnership.document_type === 'moa' || partnership.document_type === 'MoA') ? 'selected' : '' %>>MoA</option>
                 <option value="spk" <%= partnership && (partnership.document_type === 'spk' || partnership.document_type === 'SPK') ? 'selected' : '' %>>SPK</option>
            </select>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="label block mb-1">Tanggal Mulai <span class="text-red-500">*</span></label>
              <input type="date" name="start_date" class="input w-full" value="<%= partnership && partnership.start_date ? new Date(partnership.start_date).toISOString().split('T')[0] : '' %>" required />
            </div>
            <div>
              <label class="label block mb-1">Tanggal Akhir <span class="text-red-500">*</span></label>
              <input type="date" name="end_date" class="input w-full" value="<%= partnership && partnership.end_date ? new Date(partnership.end_date).toISOString().split('T')[0] : '' %>" required />
            </div>
          </div>

          <div>
            <label class="label block mb-1">Status</label>
            <select name="status" class="input w-full">
              <option value="active" <%= partnership && partnership.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="expired" <%= partnership && partnership.status === 'expired' ? 'selected' : '' %>>Expired</option>
              <option value="terminated" <%= partnership && partnership.status === 'terminated' ? 'selected' : '' %>>Terminated</option>
            </select>
          </div>

          <div class="flex gap-3 pt-4 border-t">
            <button type="submit" class="btn">Simpan Data</button>
            <a href="/kerjasama/master" class="btn-outline">Batal</a>
          </div>

        </form>
      </div>

    </div>
  </main>
</body>
</html>