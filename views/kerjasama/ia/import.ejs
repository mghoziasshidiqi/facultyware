<!doctype html>
<html lang="id">
<head>
  <script>
    (() => { try { const stored = localStorage.getItem("themeMode"); if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) { document.documentElement.classList.add("dark"); } } catch (_) {} })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> - Facultyware</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="stylesheet" href="/assets/styles.css" />
</head>
<body>
  <%- include('../../partials/sidebar') %>

  <main class="main">
    <div class="p-6 max-w-2xl mx-auto space-y-6">

      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        <a href="/kerjasama/ia" class="hover:text-foreground">Implementation Arrangement</a>
        <span>/</span>
        <span class="text-foreground">Import</span>
      </nav>

      <h1 class="text-2xl font-bold">Import Data IA</h1>

      <!-- Hasil import -->
      <% if (typeof successCount !== 'undefined' && successCount !== null) { %>
        <div class="rounded-md bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 p-4 text-green-800 dark:text-green-200 text-sm">
          ✓ Berhasil mengimpor <strong><%= successCount %></strong> data IA.
        </div>
      <% } %>

      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <div class="rounded-md bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-4">
          <p class="font-medium text-red-800 dark:text-red-200 text-sm mb-2">Terdapat <%= errors.length %> kesalahan:</p>
          <ul class="list-disc list-inside text-red-700 dark:text-red-300 text-sm space-y-1 max-h-48 overflow-y-auto">
            <% errors.forEach(e => { %><li><%= e %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <!-- Form Upload -->
      <div class="card p-6 space-y-4">
        <form method="POST" action="/kerjasama/ia/import" enctype="multipart/form-data" class="space-y-4">
          <div>
            <label for="file" class="label block mb-1">
              File CSV / Excel <span class="text-red-500">*</span>
            </label>
            <input type="file" id="file" name="file" accept=".csv,.xlsx,.xls" class="input w-full" required />
            <p class="text-xs text-muted-foreground mt-1">Maks. 5 MB. Format: .csv, .xlsx, .xls</p>
          </div>
          <div class="flex gap-3">
            <button type="submit" class="btn">Upload & Import</button>
            <a href="/kerjasama/ia" class="btn-outline">Kembali</a>
          </div>
        </form>
      </div>

      <!-- Panduan Format -->
      <div class="card p-6 space-y-3">
        <h2 class="font-semibold">Format Kolom yang Diperlukan</h2>
        <p class="text-sm text-muted-foreground">
          Baris pertama file harus berisi nama kolom berikut (penulisan huruf harus sama persis):
        </p>
        <div class="overflow-x-auto">
          <table class="table w-full text-sm">
            <thead>
              <tr>
                <th>Nama Kolom</th>
                <th>Keterangan</th>
                <th>Wajib</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><code>partnership_id</code></td>
                <td>ID kerjasama induk (dari tabel partnerships)</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>partnership_impl_id</code></td>
                <td>ID program implementasi (dari tabel partnership_implementations)</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>title</code></td>
                <td>Judul kegiatan IA</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>start_date</code></td>
                <td>Tanggal mulai (format: YYYY-MM-DD)</td>
                <td><span class="badge badge-destructive">Ya</span></td>
              </tr>
              <tr>
                <td><code>description</code></td>
                <td>Deskripsi kegiatan</td>
                <td><span class="badge bg-gray-100 text-gray-700">Opsional</span></td>
              </tr>
              <tr>
                <td><code>document_number</code></td>
                <td>Nomor dokumen IA</td>
                <td><span class="badge bg-gray-100 text-gray-700">Opsional</span></td>
              </tr>
              <tr>
                <td><code>end_date</code></td>
                <td>Tanggal akhir (format: YYYY-MM-DD)</td>
                <td><span class="badge bg-gray-100 text-gray-700">Opsional</span></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="rounded-md bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 p-3 text-blue-800 dark:text-blue-200 text-xs">
          <strong>Catatan:</strong> Kolom <code>partnership_id</code> dan <code>partnership_impl_id</code> harus berupa ID angka yang valid dan sudah ada di database.
          Upload dokumen lampiran hanya bisa dilakukan satu per satu melalui form Edit atau endpoint API.
        </div>
      </div>

    </div>
  </main>
</body>
</html>
